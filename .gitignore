# macOS
.DS_Store

# Per-user CLI state (Claude Code permission grants etc.)
.claude/

# Personal Claude project guidance — kept locally, not shared via git.
CLAUDE.md

# Obsidian (per-user editor config; not project state)
docs/.obsidian/

# Swift Package Manager
.build/
.swiftpm/
Package.resolved
*.xcodeproj
*.xcworkspace

# Bundled .app artifacts (built fresh by scripts/build-app.sh)
build/

# Xcode user data
**/xcuserdata/
**/*.xcscmblueprint

# Sidecars: Python venvs and caches (per-user, large)
Sidecars/**/.venv/
Sidecars/**/__pycache__/
Sidecars/**/*.egg-info/

# Rocky local app support (created at runtime)
.rocky/
