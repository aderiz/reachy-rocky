{
  "name": "mlx-tts",
  "version": "0.1.0",
  "binary": "{venv}/bin/python",
  "args": ["-u", "-m", "rocky_tts.runner"],
  "working_dir": "{sidecar_dir}",
  "env": {
    "ROCKY_TTS_BACKEND": "qwen3-tts",
    "ROCKY_TTS_QWEN3_MODEL": "mlx-community/Qwen3-TTS-12Hz-1.7B-Base-bf16"
  },
  "ready_event": "ready",
  "ready_timeout_s": 30,
  "shutdown_grace_s": 3,
  "restart_policy": "on_failure",
  "restart_max_per_minute": 3,
  "timeouts": {
    "*": 5,
    "synthesize": 60
  }
}
